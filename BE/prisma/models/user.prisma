model User {
  id          String    @id @default(uuid())
  email       String    @unique
  name        String?
  displayName String?
  password    String?
  isActive    Boolean   @default(true) // For soft deletion
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLogin   DateTime?
  lastLoginIp String?

  // Relations
  userRoles             UserRole[]
  userProjects          ProjectUser[]
  information           UserInfo?
  authoredTasks         Task[]           @relation("TaskAuthor")
  assignedTasks         Task[]           @relation("TaskAssignee")
  taskComments          TaskComment[]
  notifications         Notification[]
  taskAttachments       TaskAttachment[]
  grantedUserRoles      UserRole[]       @relation("UserRoleGrantedBy")
  userPermissions       UserPermission[]
  grantedUserPermission UserPermission[] @relation("UserPermissionGrantedBy")

  @@index([email], name: "idx_users_email")
  @@index([isActive], name: "idx_users_active")
  @@index([createdAt], name: "idx_users_created_at")
  @@map("users")
}

model UserInfo {
  userId      String  @unique
  bio         String?
  avatar      String?
  location    String?
  phone       String?
  timezone    String?
  preferences Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_info")
}

model UserRole {
  userId    String
  roleId    String
  grantedBy String
  grantedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  grantedByUser User @relation("UserRoleGrantedBy", fields: [grantedBy], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model UserPermission {
  userId       String
  permissionId String
  grantedBy    String
  grantedAt    DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedByUser User       @relation("UserPermissionGrantedBy", fields: [grantedBy], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}
