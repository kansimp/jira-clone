enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

model Project {
  id          String        @id @default(uuid())
  name        String
  slug        String        @unique
  description String?
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  isArchived  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members ProjectUser[]
  tasks   Task[]

  @@index([name], name: "idx_projects_name")
  @@index([status], name: "idx_projects_status")
  @@index([isArchived], name: "idx_projects_archived")
  @@index([createdAt], name: "idx_projects_created_at")
  @@map("projects")
}

model ProjectUser {
  projectId       String
  userId          String
  roleInProjectId String
  joinedAt        DateTime @default(now()) // More descriptive than createdAt
  updatedAt       DateTime @updatedAt

  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleInProject Role    @relation(fields: [roleInProjectId], references: [id])

  @@id([projectId, userId])
  @@map("project_users")
}
